<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | GalaxyBot Panel</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <div class="app-container">
        <aside class="sidebar">
            <div class="sidebar-header">
                <h2><i class="fa-solid fa-moon"></i> GalaxyBot</h2>
            </div>
            <nav class="sidebar-nav">
                <a href="/" class="<%= title === 'Dashboard' ? 'active' : '' %>"><i class="fa-solid fa-chart-pie"></i> Dashboard</a>
                <a href="/setup" class="<%= title === 'Setup Panel' ? 'active' : '' %>"><i class="fa-solid fa-bullhorn"></i> Setup</a>
                <a href="/commands" class="<%= title === 'Custom Commands' ? 'active' : '' %>"><i class="fa-solid fa-code"></i> Commands</a>
                <a href="/roles" class="<%= title === 'Reaction Roles' ? 'active' : '' %>"><i class="fa-solid fa-tags"></i> Roles</a>
                <a href="/broadcast" class="<%= title === 'Broadcast' ? 'active' : '' %>"><i class="fa-solid fa-broadcast-tower"></i> Broadcast</a>
                <a href="/tickets" class="<%= title === 'Tickets' ? 'active' : '' %>"><i class="fa-solid fa-ticket"></i> Tickets</a>
                <a href="/settings" class="<%= title === 'Settings' ? 'active' : '' %>"><i class="fa-solid fa-gear"></i> Settings</a>
            </nav>
            <div class="sidebar-footer">
                <a href="/logout"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
            </div>
        </aside>
        <main class="main-content">
            <header class="topbar">
                <h1><%= title %></h1>
                <div class="user-info">
                    <span>Admin Panel</span>
                    <div class="avatar">A</div>
                </div>
            </header>
            <div class="content-wrapper">
                <%- body %>
            </div>
        </main>
    </div>
    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        socket.on('console_log', (msg) => {
            const consoleBox = document.getElementById('console-box');
            if (consoleBox) {
                const line = document.createElement('div');
                line.style.padding = '2px 0';
                line.style.borderBottom = '1px solid #333';
                line.textContent = `> ${msg}`;
                consoleBox.appendChild(line);
                consoleBox.scrollTop = consoleBox.scrollHeight;
            }
        });
    </script>
</body>
</html>
