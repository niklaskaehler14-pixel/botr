<div class="setup-container glass-panel">
    <div class="panel-header">
        <h2>Send Bot Panels</h2>
        <p>Select a channel and the type of panel to send.</p>
    </div>

    <% if (success) { %>
        <div class="alert alert-success">
            <i class="fa-solid fa-check-circle"></i> Ticket panel sent successfully!
        </div>
    <% } %>

    <% if (error) { %>
        <div class="alert alert-error">
            <i class="fa-solid fa-triangle-exclamation"></i> <%= error %>
        </div>
    <% } %>

    <form action="/setup" method="POST" class="setup-form">
        <div class="form-group">
            <label for="panelType">Panel Type</label>
            <select name="panelType" id="panelType" required class="select-input">
                <option value="ticket" selected>Ticket Panel</option>
                <option value="verify">Verify Panel</option>
            </select>
        </div>
        <div class="form-group">
            <label for="channelId">Select Channel</label>
            <select name="channelId" id="channelId" required class="select-input">
                <option value="" disabled selected>Choose a channel...</option>
                <% if (channels.length === 0) { %>
                    <option disabled>No channels found (Is the bot online?)</option>
                <% } else { %>
                    <% channels.forEach(channel => { %>
                        <option value="<%= channel.id %>">
                            #<%= channel.name %> (<%= channel.guildName %>)
                        </option>
                    <% }); %>
                <% } %>
            </select>
            <small>The bot must have permission to send messages in the selected channel.</small>
        </div>
        
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">
                <i class="fa-solid fa-paper-plane"></i> Send Panel
            </button>
        </div>
    </form>
</div>
