<div class="settings-container glass-panel">
    <div class="panel-header">
        <h2>Broadcast Message</h2>
        <p>Send a message to a specific channel and optionally ping a role.</p>
    </div>

    <% if (success) { %>
        <div class="alert alert-success">Message sent successfully!</div>
    <% } %>

    <form action="/broadcast" method="POST" class="settings-form">
        <div class="form-group">
            <label for="channelId">Target Channel</label>
            <select id="channelId" name="channelId" required>
                <option value="">-- Select Channel --</option>
                <% channels.forEach(channel => { %>
                    <option value="<%= channel.id %>">#<%= channel.name %></option>
                <% }) %>
            </select>
            <small>Select the text channel where the message will be sent.</small>
        </div>

        <div class="form-group">
            <label for="roleId">Role to Ping (Optional)</label>
            <select id="roleId" name="roleId">
                <option value="">-- No Ping --</option>
                <% roles.forEach(role => { %>
                    <option value="<%= role.id %>">@<%= role.name %></option>
                <% }) %>
            </select>
            <small>The selected role will be pinged at the beginning of the message.</small>
        </div>

        <div class="form-group">
            <label for="message">Message Content</label>
            <textarea id="message" name="message" rows="5" placeholder="Enter your message here..." required></textarea>
            <small>You can use Discord markdown (e.g. **bold**, *italic*, \n for new line).</small>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Send Broadcast</button>
        </div>
    </form>
</div>

